PREFIX fx:  <http://sparql.xyz/facade-x/ns/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX clv: <https://w3id.org/italia/onto/CLV/>
PREFIX cpv: <https://w3id.org/italia/onto/CPV/>

CONSTRUCT {
  # Definiamo la Via
  ?viaURI a clv:Street ;
          clv:hasStreetName ?nomeIntero .

  # Colleghiamo alla Persona SOLO se supera il filtro
  ?viaURI clv:isDedicatedTo ?personaURI .
  ?personaURI a cpv:Person ;
              cpv:fullName ?nomePulito .
}
WHERE {
  SERVICE <x-sparql-anything:location=rifter_arcstra_table.csv,csv.headers=false> {
    ?row rdf:_1 ?lineaIntera .
  }
  
  FILTER(!STRSTARTS(STR(?lineaIntera), "CODARCO") && !STRSTARTS(STR(?lineaIntera), "ODARCO"))
  
  BIND(STRAFTER(STR(?lineaIntera), ";") AS ?dopoCodArco)
  BIND(STRBEFORE(?dopoCodArco, ";") AS ?codVia)
  BIND(STRAFTER(?dopoCodArco, ";") AS ?dopoCodVia)
  BIND(STRBEFORE(?dopoCodVia, ";") AS ?nomeIntero)

  # --- LOGICA DI PULIZIA AGGRESSIVA ---
  # 1. Rimuoviamo gli spazi ai bordi
  BIND(REPLACE(STR(?nomeIntero), "^\\s+|\\s+$", "") AS ?nomeTrim)
  
  # 2. Isolianto il nome rimuovendo VIA, VIALE, PIAZZA, ecc.
  BIND(REPLACE(?nomeTrim, "^(VIA|PIAZZA|STRADA|VIALE|VICOLO|LARGO|ROTONDA|CORSO|STRETTOIA|MURA|PONTE|SOTTOPASSO|RAMPA|GIARDINO|PARCO) ", "", "i") AS ?nomePulito)

  # 3. FILTRO STRATEGICO: Escludiamo i concetti palesemente non umani
  # Se il nome pulito inizia con "DEL ", "DEI ", "DI " (spesso toponimi) o è troppo corto, lo scartiamo
  FILTER(!REGEX(?nomePulito, "^(DEL |DEI |DEGLI |AL |ALLA |AI |SANT'|SANTA |SAN |VECCHIA|NUOVA|ESTRO|MURA|AUTOSTRADA)", "i"))
  FILTER(STRLEN(?nomePulito) > 4)

  # Generazione URI
  BIND(IRI(CONCAT("https://w3id.org/bologna/resource/street/", ?codVia)) AS ?viaURI)
  BIND(IRI(CONCAT("https://w3id.org/bologna/resource/person/", MD5(?nomePulito))) AS ?personaURI)
}