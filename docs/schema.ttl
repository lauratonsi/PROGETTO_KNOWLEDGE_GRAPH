@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix clv:  <https://w3id.org/italia/onto/CLV/> .
@prefix cpv:  <https://w3id.org/italia/onto/CPV/> .
@prefix ex:   <https://w3id.org/bologna/ontology#> .

# ── Ontology ──────────────────────────────────────────────────────────────────

<https://w3id.org/bologna/ontology>
    a owl:Ontology ;
    rdfs:label "Ontologia Toponomastica di Bologna"@it ;
    rdfs:label "Bologna Street Toponymy Ontology"@en ;
    rdfs:comment "Ontologia per la classificazione di genere della toponomastica del Comune di Bologna. Riutilizza CLV e CPV (vocabolari controllati italiani) ed estende con proprietà custom per la gestione delle proposte di intitolazione."@it .

# ── Classes ───────────────────────────────────────────────────────────────────

clv:Street
    a owl:Class ;
    rdfs:label "Strada"@it ;
    rdfs:label "Street"@en ;
    rdfs:comment "Arco stradale del grafo viario del Comune di Bologna (via, piazza, viale, passaggio, largo, ecc.)."@it .

cpv:Person
    a owl:Class ;
    rdfs:label "Persona"@it ;
    rdfs:label "Person"@en ;
    rdfs:comment "Persona storica a cui è intitolata una strada, oppure candidatura proposta per una futura intitolazione."@it .

# ── Object Property ───────────────────────────────────────────────────────────

clv:isDedicatedTo
    a owl:ObjectProperty ;
    rdfs:label "è dedicata a"@it ;
    rdfs:label "is dedicated to"@en ;
    rdfs:domain clv:Street ;
    rdfs:range  cpv:Person ;
    rdfs:comment "Collega una strada alla persona a cui è intitolata (solo strade Male o Female)."@it .

# ── Datatype Properties (rilevanti per l'analisi) ─────────────────────────────

clv:hasStreetName
    a owl:DatatypeProperty ;
    rdfs:label "nome della strada"@it ;
    rdfs:label "street name"@en ;
    rdfs:domain clv:Street ;
    rdfs:range  xsd:string .

cpv:sex
    a owl:DatatypeProperty ;
    rdfs:label "classificazione di genere"@it ;
    rdfs:label "gender classification"@en ;
    rdfs:domain cpv:Person ;
    rdfs:range  xsd:string ;
    rdfs:comment "Valori: 'Male', 'Female', 'Toponimo'."@it .

ex:professione
    a owl:DatatypeProperty ;
    rdfs:label "professione"@it ;
    rdfs:label "occupation"@en ;
    rdfs:domain cpv:Person ;
    rdfs:range  xsd:string ;
    rdfs:comment "Ricavata da Wikidata P106 o fonti archivistiche locali."@it .

ex:proposta
    a owl:DatatypeProperty ;
    rdfs:label "proposta di intitolazione"@it ;
    rdfs:label "naming proposal"@en ;
    rdfs:domain cpv:Person ;
    rdfs:range  xsd:string ;
    rdfs:comment "Valore 'true' per le candidature proposte dal gruppo di ricerca."@it .

ex:statoProposta
    a owl:DatatypeProperty ;
    rdfs:label "stato della proposta"@it ;
    rdfs:label "proposal status"@en ;
    rdfs:domain cpv:Person ;
    rdfs:range  xsd:string ;
    rdfs:comment "Valori: 'attiva' (decesso >10 anni) o 'futura' (decesso <10 anni o persona in vita)."@it .

# ── Annotation Properties (metadati biografici) ───────────────────────────────

cpv:fullName
    a owl:AnnotationProperty ;
    rdfs:label "nome completo"@it ;
    rdfs:label "full name"@en ;
    rdfs:domain cpv:Person .

ex:dataNascita
    a owl:AnnotationProperty ;
    rdfs:label "data di nascita"@it ;
    rdfs:label "date of birth"@en ;
    rdfs:comment "Wikidata P569."@it .

ex:luogoNascita
    a owl:AnnotationProperty ;
    rdfs:label "luogo di nascita"@it ;
    rdfs:label "place of birth"@en ;
    rdfs:comment "Wikidata P19."@it .

ex:dataMorte
    a owl:AnnotationProperty ;
    rdfs:label "data di morte"@it ;
    rdfs:label "date of death"@en ;
    rdfs:comment "Wikidata P570."@it .

ex:luogoMorte
    a owl:AnnotationProperty ;
    rdfs:label "luogo di morte"@it ;
    rdfs:label "place of death"@en ;
    rdfs:comment "Wikidata P20."@it .
