## Query 4 — REGEX + UNION: strade "Fratelli" e donne con "Maria" nel nome
## Una sola query che combina due ricerche tematiche con UNION.
## Keywords: REGEX, UNION, FILTER, BIND, DISTINCT, ORDER BY

PREFIX clv: <https://w3id.org/italia/onto/CLV/>
PREFIX cpv: <https://w3id.org/italia/onto/CPV/>

SELECT DISTINCT ?tipo ?nomeVia ?nomePersona
WHERE {
  {
    ## 4a — Strade con "FRATELLI": il maschile grammaticale oscura la presenza femminile
    ?via a clv:Street ;
         clv:hasStreetName ?nomeVia ;
         clv:isDedicatedTo ?persona .
    ?persona cpv:fullName ?nomePersona .
    FILTER(REGEX(?nomeVia, "FRATELLI", "i"))
    BIND("Fratelli" AS ?tipo)
  }
  UNION
  {
    ## 4b — Donne onorate con "MARIA" nel nome
    ?via a clv:Street ;
         clv:hasStreetName ?nomeVia ;
         clv:isDedicatedTo ?persona .
    ?persona cpv:fullName ?nomePersona ;
             cpv:sex "Female" .
    FILTER(REGEX(?nomePersona, "MARIA", "i"))
    BIND("Maria" AS ?tipo)
  }
}
ORDER BY ?tipo ?nomeVia
